# Caddy reverse proxy config
# Auto-HTTPS via Let's Encrypt

manoj-dahal.com.np, www.manoj-dahal.com.np {
    # Redirect www to non-www
    @www host www.manoj-dahal.com.np
    handle_response @www {
        redir https://manoj-dahal.com.np{uri} permanent
    }

    # Reverse proxy to the Node app
    reverse_proxy app:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        # HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent MIME-sniffing
        X-Content-Type-Options "nosniff"
        # Clickjacking protection
        X-Frame-Options "DENY"
        # XSS filter
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Permissions
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        # Remove server header
        -Server
    }

    # Compression
    encode zstd gzip

    # Cache static assets aggressively
    @assets path /assets/* /css/* /js/* /admin/css/* /admin/js/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # Cache HTML briefly
    @html path *.html
    header @html Cache-Control "public, max-age=0, must-revalidate"

    # Logging
    log {
        output file /data/access.log {
            roll_size 100mb
            roll_keep 10
        }
    }
}

# Admin sub-path (optional — could be on a separate subdomain)
admin.manoj-dahal.com.np {
    reverse_proxy app:3000
    basicauth {
        admin $2a$14$YOUR_BCRYPT_HASH_HERE
    }
}
